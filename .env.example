# Copy to .env and fill in your own values. NEVER commit .env.

# --- Web app (apps/web) ---
# Base URL of the deployed netundo API worker (workers/api).
NEXT_PUBLIC_API_WORKER_URL=https://your-api-worker.example.workers.dev

# Optional: self-hosted speed-test measurement worker (workers/speedtest).
# Leave UNSET to measure against Cloudflare's global endpoints (most accurate).
# NEXT_PUBLIC_SPEEDTEST_WORKER_URL=https://speed.example.com

# --- Supabase ---
# Project URL is safe to expose. The anon key is also public by design.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# SECRET — never commit. Set on the API worker with:
#   wrangler secret put SUPABASE_SERVICE_KEY
# (kept out of the repo; do not paste the real value here)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

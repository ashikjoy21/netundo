{
  "name": "netundo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "deploy:speedtest": "pnpm --filter=@netundo/worker-speedtest run deploy",
    "deploy:api": "pnpm --filter=@netundo/worker-api run deploy",
    "deploy:web": "pnpm --filter=@netundo/web run deploy",
    "ingest:trai": "node scripts/ingest-trai.mjs",
    "ingest:mlab": "node scripts/ingest-mlab.mjs"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
